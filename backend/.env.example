# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=carpoolutec
DB_PASSWORD=change_me
DB_NAME=carpoolutec_db

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# JWT — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRATION=7d

# Expo deep-link base URL
# Development:  exp://127.0.0.1:8081/--/login
# Production:   myapp://login
EXPO_REDIRECT_URL=exp://127.0.0.1:8081/--/login

# Environment
NODE_ENV=development

# CORS: comma-separated list of allowed client origins
ALLOWED_ORIGINS=exp://127.0.0.1:8081,exp://localhost:8081

# Google Maps (backend geo queries)
GOOGLE_MAPS_KEY=your_google_maps_api_key
